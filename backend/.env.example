# ── Emouva backend configuration ─────────────────────────────────────────────
# Copy to backend/.env and fill in. Everything not marked REQUIRED has a sane
# default — a fresh install runs with just the database + JWT secret.

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Postgres (docker compose up -d provisions one matching this URL)
DATABASE_URL=postgresql+asyncpg://aegis:changeme@localhost:5432/aegis
# Sign your session tokens with something long and random
JWT_SECRET=change-me-to-something-long-and-random

# ── AI (the brain) ───────────────────────────────────────────────────────────
# Interactive research/advisor runs on each user's own key (Settings → AI Token).
# The SCHEDULED jobs (agent ticks, central-pool analysis, theme monitoring) run
# server-side and need a key here — on a personal install, that's your own key.
ANTHROPIC_KEY=
# CLAUDE_MODEL=claude-sonnet-5

# ── Market data (all optional — free fallback works keyless) ────────────────
# FMP is the best source (reliable FCF, analyst targets, search, news, earnings
# calendar). Without it, quotes/fundamentals/history fall through to Finnhub and
# yfinance for free; FMP-only extras (news feed, earnings-triggered re-thesis)
# quietly turn off.
FMP_API_KEY=
FINNHUB_API_KEY=
# MARKET_PROVIDER_ORDER=fmp,finnhub,yfinance

# ── Robinhood (local-first OAuth) ────────────────────────────────────────────
# The default redirect already points at your local backend — only change this
# if you host the backend somewhere else.
# EMOUVA_RH_REDIRECT_URI=http://localhost:8001/api/robinhood/callback
# EMOUVA_FRONTEND_URL=http://localhost:5174

# ── Live-trading safety gates (all fail-closed; defaults OFF) ───────────────
# Flip these only after you've watched the agent on paper money.
# LIVE_EXECUTION_ENABLED=false     # master gate for real Robinhood orders
# THEMES_LIVE_ENABLED=false        # real-money theme (Polytrade) execution
# TRADING_HALT=false               # global kill switch — true halts everything
# LIVE_MAX_NOTIONAL_USD=100        # platform ceiling per live order

# ── Personal hosted mode (leave unset for self-hosting) ─────────────────────
# On a shared/hosted deployment, restrict trading features to these usernames;
# everyone else can still sign up for the community.
# RESTRICT_TRADING_TO=

# ── Token vault (optional) ──────────────────────────────────────────────────
# Encrypts stored Robinhood OAuth tokens; falls back to JWT_SECRET when unset.
# EMOUVA_TOKEN_KEY=
